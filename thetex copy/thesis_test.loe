\contentsline {equations}{\numberline {5.1}\text {Loss}_{x,y} = \DOTSB \sum@ \slimits@ _{i=0}^{a} \DOTSB \sum@ \slimits@ _{j=0}^{g^{2}} \alpha _{ji}^{\text {trg}} \left [ (x_{\text {gt}} - x_{\text {pred}})^{2} + (y_{\text {gt}} - y_{\text {pred}})^{2} \right ], \hskip 1em\relax \alpha \in \{0,1\} }{220}{equation.5.1}%
\contentsline {equations}{\numberline {5.2}\text {Loss}_{h,w} = \DOTSB \sum@ \slimits@ _{i=0}^{a} \DOTSB \sum@ \slimits@ _{j=0}^{g^{2}} \alpha _{ji}^{\text {trg}} \left [ (h_{\text {gt}} - h_{\text {pred}})^{2} + (w_{\text {gt}} - w_{\text {pred}})^{2} \right ], \hskip 1em\relax \alpha \in \{0,1\} }{220}{equation.5.2}%
\contentsline {equations}{\numberline {5.3}\text {Loss}_{C} = \DOTSB \sum@ \slimits@ _{i=0}^{a} \DOTSB \sum@ \slimits@ _{j=0}^{g^{2}} \alpha _{ji}^{\text {trg}} \left [ (C_{\text {gt}} - C_{\text {pred}})^{2} \right ], \hskip 1em\relax C_{\text {gt}} \in \{1\} }{220}{equation.5.3}%
\contentsline {equations}{\numberline {5.4}\text {Loss}_{p_{\text {gt}}^{\text {cls}}} = \DOTSB \sum@ \slimits@ _{i=0}^{a} \DOTSB \sum@ \slimits@ _{j=0}^{g^{2}} \alpha _{ji}^{\text {trg}} \left [ (p_{\text {gt}}^{\text {cls}} - p_{\text {pred}}^{\text {cls}})^{2} \right ], \hskip 1em\relax 0 \leq p_{\text {pred}}^{\text {cls}} \leq 1 }{221}{equation.5.4}%
